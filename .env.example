# Copy to .env for local dev. On Netlify: Site settings → Environment variables → add each key.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login
ADMIN_EMAIL=mbplingerie@gmail.com
ADMIN_PASSWORD=your-admin-password
JWT_SECRET=your-long-random-jwt-secret

# Legacy aliases (optional — server also reads these from old backend/.env)
# ADMIN_LOGIN_EMAIL=mbplingerie@gmail.com
# ADMIN_LOGIN_PASSWORD=your-admin-password
# ADMIN_TOKEN_SECRET=your-long-random-jwt-secret

# Site URLs (no trailing slash)
PUBLIC_SITE_URL=https://mbp-frontend.netlify.app
FRONTEND_ORIGIN=https://mbp-frontend.netlify.app

# Paystack
PAYSTACK_SECRET_KEY=sk_test_or_sk_live_xxx
PAYSTACK_CALLBACK_URL=https://mbp-frontend.netlify.app/cart.html

# Resend order emails
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=MBP Lingerie <orders@mbplingerie.com.ng>
ADMIN_ORDER_EMAIL=mbplingerie@gmail.com

# Local dev only
PORT=4000
